@{
    ViewData["Title"] = "Resumen de Compra";
    var listaCombos = ViewBag.ListaCombos as List<CinepolisApp.Controllers.CompraController.ComboElegidoDTO>;
}

<div class="container mt-4" style="max-width: 650px;">
    <div class="card shadow border-0 p-4">
        <h3 class="fw-bold text-primary text-center mb-4">💳 RESUMEN DE TU RESERVA</h3>

        <div class="bg-light p-3 rounded mb-3 border">
            <h6 class="fw-bold text-dark border-bottom pb-2 mb-2">🎟️ ENTRADAS SELECCIONADAS</h6>
            <div class="d-flex justify-content-between small">
                <span><strong>Butacas:</strong> <span class="text-primary">@ViewBag.Asientos</span></span>
                <span>@ViewBag.CantidadEntradas tickets x S/ 15.00</span>
            </div>
            <p class="text-end fw-bold text-dark mb-0 mt-2">Subtotal Entradas: S/ @ViewBag.TotalEntradas.ToString("F2")</p>
        </div>

        <div class="bg-light p-3 rounded mb-4 border">
            <h6 class="fw-bold text-dark border-bottom pb-2 mb-2">🍿 SNACKS Y COMBOS</h6>
            @if (listaCombos != null && listaCombos.Count > 0)
            {
                @foreach (var combo in listaCombos)
                {
                    <div class="d-flex justify-content-between small mb-1">
                        <span>@combo.Nombre <strong class="text-muted">x@combo.Cantidad</strong></span>
                        <span>S/ @combo.Subtotal.ToString("F2")</span>
                    </div>
                }
                <p class="text-end fw-bold text-dark mb-0 border-top pt-2 mt-2">Subtotal Dulcería: S/ @ViewBag.TotalCombos.ToString("F2")</p>
            }
            else
            {
                <p class="text-muted small mb-0">No agregaste snacks a tu función.</p>
            }
        </div>

        <form asp-action="TerminarCompra" method="post">
            <h5 class="fw-bold text-dark mb-3">👤 Datos para el Ticket</h5>

            <div class="mb-3">
                <label class="form-label small fw-bold text-muted">Nombre Completo del Titular</label>
                <input type="text" name="clienteNombre" class="form-control" placeholder="Ej. Juan Pérez" required />
            </div>

            <div class="mb-4">
                <label class="form-label small fw-bold text-muted">Número de DNI</label>
                <input type="text" name="clienteDni" class="form-control" maxlength="8" placeholder="8 dígitos" required onkeypress="return (event.charCode >= 48 && event.charCode <= 57)" />
            </div>

            <div class="d-flex justify-content-between align-items-center border-top pt-3 mb-4">
                <h4 class="fw-bold text-dark mb-0">TOTAL A PAGAR:</h4>
                <h3 class="fw-bold text-success mb-0">S/ @ViewBag.TotalPagar.ToString("F2")</h3>
            </div>

            <div class="d-flex gap-2">
                <a href="@Url.Action("SeleccionarCombos", "Compra")" class="btn btn-light border fw-bold w-25">⬅️ Volver</a>
                <button type="submit" class="btn btn-success w-75 fw-bold fs-5 shadow-sm">
                    🔒 Finalizar y Pagar S/ @ViewBag.TotalPagar.ToString("F2")
                </button>
            </div>
        </form>
    </div>
</div>